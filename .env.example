# Groq API key (required)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Notion OAuth credentials (required for web UI)
# Get these from: notion.so → Listings → Integrations → New Integration
NOTION_OAUTH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_OAUTH_CLIENT_SECRET=secret_xxxxxxxxxxxxxxxxxxxx
REDIRECT_URI=https://<your-railway-url>/auth/callback

# Optional: personal API token for local CLI usage (python main.py wrapped)
NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx
